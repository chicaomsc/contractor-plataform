# Contractor Platform — production environment (Sprint 11A.1)
#
# Copy this file to `production.env` (same directory) and fill in real values.
# `production.env` must NEVER be committed — it already matches the repo-root
# .gitignore pattern `.env*`, but double-check with `git status` before committing
# anything in this directory.
#
# Every value below either configures `docker compose` itself (image names, the
# version tag, host port publishing) or is passed straight through to a container
# via `env_file:` in docker-compose.prod.yml. Where a variable name requested by a
# generic checklist didn't match anything this codebase actually reads (e.g.
# SPRING_DATASOURCE_URL, CORS_ALLOWED_ORIGINS, UPLOAD_DIRECTORY, JWT_REFRESH_SECRET,
# NEXT_PUBLIC_API_URL, PUBLIC_APP_URL/PUBLIC_API_URL), it is called out explicitly
# below instead of being silently invented — see backend's application.yml and
# frontend's src/lib/env/public-env.ts for the source of truth.

# ── docker compose itself ───────────────────────────────────────────────────
# Prefixes container/network/volume names (e.g. contractor_backend_1). Optional —
# compose defaults to the containing directory name if unset.
COMPOSE_PROJECT_NAME=contractor-platform

# Image references. GHCR publishing itself is out of scope for this sprint (see
# infra/README.md) — for now these can point at anything reachable by the host
# (e.g. an image built locally with `docker compose build`).
BACKEND_IMAGE=ghcr.io/chicaodw/contractor-platform-backend
FRONTEND_IMAGE=ghcr.io/chicaodw/contractor-platform-frontend

# Immutable tag for both images. Use a commit SHA in real deployments
# (e.g. APP_VERSION=a1b2c3d) once CI publishes images — "local" is only for
# `docker compose build`, which tags the image with this value.
APP_VERSION=local

# Temporary direct host port publishing — removed/reconsidered once Caddy (Sprint
# 11A.3) becomes the only public entrypoint. Safe to leave at the defaults.
# BACKEND_PORT=8080
#
# Host port published locally before Caddy exists. Only the host side is
# configurable — the container always listens on 3000 internally, regardless of
# this value. Change this if port 3000 is already taken by another project on the
# same machine (e.g. set FRONTEND_HOST_PORT=3001) instead of stopping the other
# project. In production, once Caddy is introduced (Sprint 11A.3), this direct
# host publication goes away entirely and this variable stops being read.
FRONTEND_HOST_PORT=3000

# ── PostgreSQL (spring.datasource.* is derived FROM these — do not set
#    DB_URL/DB_USERNAME/DB_PASSWORD separately, see docker-compose.prod.yml) ──
POSTGRES_DB=platform_db
POSTGRES_USER=platform
POSTGRES_PASSWORD=CHANGE_ME_WITH_A_STRONG_SECRET

# ── Backend (Spring Boot — see backend/src/main/resources/application.yml) ──
# No dedicated Spring profile is activated in production at this stage: the base
# application.yml is already production-safe by default (hidden error details,
# actuator show-details=when-authorized). Only application-local.yml (dev
# conveniences: SQL logging, permissive actuator) must be avoided — leave this
# unset/empty rather than inventing a "prod" profile that doesn't exist yet.
# SPRING_PROFILES_ACTIVE=

# app.jwt.secret — HS256 requires >= 32 bytes. This example value is intentionally
# unusable; generate a real one with e.g. `openssl rand -base64 48`.
JWT_SECRET=CHANGE_ME_WITH_A_STRONG_SECRET_MIN_32_CHARS
# There is no separate refresh-token secret to set: refresh tokens are opaque
# random strings persisted in the `refresh_tokens` table (auth.domain.RefreshToken),
# not signed JWTs — JWT_REFRESH_SECRET does not apply to this codebase.

# app.cors.allowed-origins (Spring relaxed binding: APP_CORS_ALLOWED_ORIGINS, not
# CORS_ALLOWED_ORIGINS) — comma-separated list of origins allowed to call the API.
APP_CORS_ALLOWED_ORIGINS=https://CHANGE_ME.example.com

# Optional JVM heap override — the defaults already applied in
# docker-compose.prod.yml (-XX:MaxRAMPercentage=70 etc.) are usually sufficient;
# only set this to add flags beyond those.
# JAVA_TOOL_OPTIONS=

# ── Frontend (Next.js — see frontend/src/lib/env/public-env.ts) ────────────
# NEXT_PUBLIC_* values are inlined into the client JS bundle at Docker BUILD time
# (frontend/Dockerfile ARGs), not read at container startup — changing any of the
# three below requires rebuilding the frontend image, not just restarting the
# container. They are also passed through as runtime env vars for the Next.js
# server process itself (next.config.ts reads NEXT_PUBLIC_API_BASE_URL to derive
# its CSP connect-src), which is why they are listed here too.
NEXT_PUBLIC_API_BASE_URL=https://api.CHANGE_ME.example.com
NEXT_PUBLIC_COMPANY_SLUG=CHANGE_ME_TENANT_SLUG
NEXT_PUBLIC_SITE_URL=https://CHANGE_ME.example.com

# Optional Node heap override — docker-compose.prod.yml already sets
# NODE_OPTIONS=--max-old-space-size=512 for the frontend service; only set this to
# override that default.
# NODE_OPTIONS=
